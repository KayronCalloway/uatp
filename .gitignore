# Environments
.venv/
venv/
env/

# IDE / Editor
.idea/
.vscode/

# Secrets
.env
.env.*
!.env.example

# Python artifacts
__pycache__/
*.pyc
*.pyo
*.pyd

# Test artifacts
.pytest_cache/
.coverage
htmlcov/

# Database files
*.sqlite3
*.db
file:memdb_*
:memory:*

# Docker
docker-compose.override.yml

# Backup files
backups/

# Log files
*.log
auto-capture-*.log
claude_capture.log

# Large documentation files (can be regenerated)
docs/**/*.pdf

# UATP Runtime
*.pid
api_server.log
frontend.log
frontend/.next/
frontend/node_modules/

# System Status
SYSTEM_STATUS.md

# Build artifacts
build/
dist/
*.egg-info/
.pre-commit-cache/
.hypothesis/

# Test/runtime data
chain_seals/
federation_data/

# ============================================
# SENSITIVE - NEVER COMMIT
# ============================================

# User private keys (CRITICAL - never commit)
.uatp_keys/
~/.uatp/
*.key
*.pem
!*.pem.example

# Deployment secrets
deployment/environments/*.env
!deployment/environments/*.env.example

# Any encrypted keys
*.enc
*.encrypted

# Backup files that might contain keys
*.key.bak
*.pem.bak

# ============================================
# END SENSITIVE
# ============================================
