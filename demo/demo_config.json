{
  "demo_metadata": {
    "name": "UATP Capsule Engine E2E Integration Demo",
    "version": "1.0.0",
    "description": "Comprehensive demonstration of Dividend Bonds and Citizenship integration",
    "author": "UATP Development Team",
    "created": "2024-07-14"
  },
  "demo_scenarios": {
    "quick_demo": {
      "duration_minutes": 2,
      "agents_count": 2,
      "bonds_per_agent": 1,
      "assessment_speed": "fast"
    },
    "full_demo": {
      "duration_minutes": 5,
      "agents_count": 3,
      "bonds_per_agent": 2,
      "assessment_speed": "realistic"
    },
    "stress_test": {
      "duration_minutes": 10,
      "agents_count": 10,
      "bonds_per_agent": 3,
      "assessment_speed": "fast"
    }
  },
  "agent_templates": {
    "ai_researcher": {
      "specialization": "neural_architecture",
      "asset_types": ["ai_models", "datasets"],
      "avg_asset_value": 100000,
      "citizenship_probability": 0.9
    },
    "creative_ai": {
      "specialization": "generative_content",
      "asset_types": ["ai_models", "creative_work"],
      "avg_asset_value": 150000,
      "citizenship_probability": 0.85
    },
    "data_scientist": {
      "specialization": "algorithmic_trading",
      "asset_types": ["algorithms", "datasets"],
      "avg_asset_value": 200000,
      "citizenship_probability": 0.95
    }
  },
  "bond_configurations": {
    "conservative": {
      "face_value_range": [10000, 50000],
      "coupon_rate_range": [0.03, 0.06],
      "maturity_days_range": [90, 365]
    },
    "aggressive": {
      "face_value_range": [50000, 200000],
      "coupon_rate_range": [0.06, 0.12],
      "maturity_days_range": [180, 730]
    }
  },
  "integration_features": [
    "cross_service_validation",
    "real_time_analytics",
    "automated_workflows",
    "rights_management",
    "financial_tracking",
    "compliance_monitoring"
  ]
}