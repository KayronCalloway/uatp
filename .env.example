# UATP Capsule Engine Environment Configuration
# Copy this file to .env and update values for your environment
#
# =============================================================================
# PRODUCTION REQUIREMENTS CHECKLIST
# =============================================================================
# The following variables MUST be set in production (app will refuse to start):
#
# SECURITY SECRETS:
#   - CSRF_SECRET_KEY (min 32 chars)
#   - JWT_SECRET or JWT_SECRET_KEY (min 32 chars)
#   - ENCRYPTION_KEY
#
# DATABASE:
#   - DB_PASSWORD (must not be a placeholder value)
#
# HOSTS:
#   - ALLOWED_HOSTS (comma-separated list of valid hostnames)
#   - CORS_ORIGINS (comma-separated list of allowed origins)
#
# REDIS (if using Redis-backed rate limiting):
#   - REDIS_PASSWORD (must not be a placeholder value)
#
# Generate secrets with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(64))"
# =============================================================================

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
# Environment: development | test | production
# This determines which database and settings to use
ENVIRONMENT=development
LOG_LEVEL=INFO
API_VERSION=v1

# Data Separation Settings
# When true, test data is excluded from API responses by default
EXCLUDE_TEST_DATA_BY_DEFAULT=true

# Application Ports
# IMPORTANT: Health endpoints (/health, /ready) are served on the main APP_PORT
# There is no separate health port - previous configs using 8080 were incorrect
APP_PORT=8000
API_PORT=8000
METRICS_PORT=9090

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# NAMING CONVENTION NOTE:
# The codebase supports two naming conventions for database variables:
#   - DB_* (canonical, used by docker-compose) - PREFERRED
#   - POSTGRES_* (legacy, for backwards compatibility)
# If both are set, DB_* takes precedence.
#
# Production Database
# SECURITY: Generate strong passwords - never use these defaults in production!
# Generate with: openssl rand -base64 32
DB_HOST=localhost
DB_PORT=5432
DB_NAME=uatp_capsule_engine
DB_USERNAME=CHANGE_ME_DB_USERNAME
DB_PASSWORD=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32

# Legacy alternative names (supported but DB_* preferred)
# POSTGRES_HOST=localhost
# POSTGRES_DB=uatp_capsule_engine
# POSTGRES_USER=CHANGE_ME
# POSTGRES_PASSWORD=CHANGE_ME

# Test Database (for automated testing - keeps test data separate)
TEST_DATABASE_URL=postgresql://CHANGE_ME:CHANGE_ME@localhost:5432/uatp_test
# Alternative: Use SQLite for faster test execution
# TEST_DATABASE_URL=sqlite:///./uatp_test.db

# Development Database (for local development)
DEV_DATABASE_URL=postgresql://CHANGE_ME:CHANGE_ME@localhost:5432/uatp_dev

# Connection Pool Settings
DB_MIN_CONNECTIONS=5
DB_MAX_CONNECTIONS=20
DB_MAX_INACTIVE_TIME=300.0
DB_CONNECTION_TIMEOUT=60.0
DB_COMMAND_TIMEOUT=60.0

# SSL Settings
DB_SSL_ENABLED=false
DB_SSL_CERT_PATH=
DB_SSL_KEY_PATH=
DB_SSL_CA_PATH=

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
# SECURITY: Generate strong passwords - never use defaults in production!
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32
REDIS_DB=0

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# SECURITY WARNING: All secrets below MUST be changed before production use!
# The application will refuse to start in production with placeholder values.

# CSRF Protection (REQUIRED in production - minimum 32 characters)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
CSRF_SECRET_KEY=CHANGE_ME_GENERATE_WITH_python_secrets_token_urlsafe_32

# JWT Settings (REQUIRED - Generate secure keys in production, minimum 32 characters)
# Note: Both JWT_SECRET and JWT_SECRET_KEY are supported for backwards compatibility
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=CHANGE_ME_GENERATE_64_BYTE_SECRET_WITH_python_secrets_token_urlsafe_64
JWT_SECRET_KEY=CHANGE_ME_GENERATE_64_BYTE_SECRET_WITH_python_secrets_token_urlsafe_64
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ISSUER=uatp_capsule_engine
JWT_AUDIENCE=uatp_api

# Encryption (REQUIRED - Generate secure key in production)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=CHANGE_ME_GENERATE_32_BYTE_SECRET_WITH_python_secrets_token_urlsafe_32

# Password Requirements
MIN_PASSWORD_LENGTH=8
REQUIRE_UPPERCASE=true
REQUIRE_LOWERCASE=true
REQUIRE_NUMBERS=true
REQUIRE_SPECIAL_CHARS=true

# Account Security
MAX_FAILED_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30
SESSION_TIMEOUT_HOURS=24
MAX_CONCURRENT_SESSIONS=3

# =============================================================================
# API CONFIGURATION
# =============================================================================

# Allowed Hosts (REQUIRED in production)
# Comma-separated list of valid hostnames for request validation
# SECURITY: Must be set in production - the app will refuse to start without it
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS Settings
# Both CORS_ORIGINS (canonical) and CORS_ALLOWED_ORIGINS (legacy) are supported
# CORS_ORIGINS takes precedence if both are set
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8501

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10
RATE_LIMIT_USE_REDIS=true

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================
# Prometheus
PROMETHEUS_PORT=9091
PROMETHEUS_METRICS_ENABLED=true

# Grafana
# SECURITY: Change these credentials before production use!
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=CHANGE_ME_GRAFANA_ADMIN
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# Elasticsearch (optional)
ELASTICSEARCH_PORT=9200

# =============================================================================
# NGINX CONFIGURATION
# =============================================================================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================
# Email Service (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@uatp.com

# SendGrid (alternative email provider for password reset)
# Get your API key from https://sendgrid.com/
SENDGRID_API_KEY=your-sendgrid-api-key

# Payment Gateway (example - Stripe)
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Cloud Storage (example - AWS S3)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=uatp-storage
AWS_REGION=us-east-1

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
# Development Database (SQLite for local dev)
DEV_DB_URL=sqlite:///./uatp_dev.db

# Debug Settings
DEBUG=false
TESTING=false

# Hot Reload
RELOAD=false

# =============================================================================
# PRODUCTION SETTINGS
# =============================================================================
# Production Security Headers
SECURE_SSL_REDIRECT=true
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
SECURE_HSTS_SECONDS=31536000
SECURE_CONTENT_TYPE_NOSNIFF=true
SECURE_BROWSER_XSS_FILTER=true

# Production Logging
LOG_FORMAT=json
LOG_FILE=/app/logs/uatp.log
ACCESS_LOG=/app/logs/access.log
ERROR_LOG=/app/logs/error.log

# Backup Settings
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_SWAGGER_UI=true
ENABLE_METRICS_ENDPOINT=true
ENABLE_HEALTH_ENDPOINT=true
ENABLE_AUDIT_LOGGING=true
ENABLE_REAL_TIME_EVENTS=true

# =============================================================================
# BUSINESS LOGIC SETTINGS
# =============================================================================
# Citizenship Assessment
CITIZENSHIP_ASSESSMENT_TIMEOUT_MINUTES=30
CITIZENSHIP_VALIDITY_MONTHS=12

# Bond Settings
DEFAULT_BOND_MATURITY_YEARS=1
MIN_BOND_VALUE=1000
MAX_BOND_VALUE=1000000

# Agent Management
MAX_AGENTS_PER_USER=10
AGENT_VERIFICATION_REQUIRED=true
