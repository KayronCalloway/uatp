# Backup Service Dockerfile
FROM python:3.12-slim

# Install required packages
RUN apt-get update && apt-get install -y \
    postgresql-client \
    curl \
    cron \
    aws-cli \
    gzip \
    && rm -rf /var/lib/apt/lists/*

# Create backup user
RUN useradd -r -s /bin/bash backup

# Install Python dependencies for backup scripts
RUN pip install boto3 requests python-dateutil croniter

# Copy backup scripts
COPY deployment/scripts/backup/ /usr/local/bin/
COPY deployment/scripts/recovery/ /usr/local/bin/

# Make scripts executable
RUN chmod +x /usr/local/bin/*.sh /usr/local/bin/*.py

# Create directories
RUN mkdir -p /backups /logs /config && \
    chown -R backup:backup /backups /logs /config

# Switch to backup user
USER backup

# Set working directory
WORKDIR /backups

# Default command
CMD ["/usr/local/bin/backup-scheduler.sh"]