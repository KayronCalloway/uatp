# UATP Development Environment Configuration

# Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# Database
DATABASE_URL=postgresql://uatp_dev:dev_password@postgres-dev:5432/uatp_dev
DATABASE_HOST=postgres-dev
DATABASE_PORT=5432
DATABASE_NAME=uatp_dev
DATABASE_USER=uatp_dev
DATABASE_PASSWORD=dev_password
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://redis-dev:6379/0
REDIS_HOST=redis-dev
REDIS_PORT=6379
REDIS_DB=0
REDIS_MAXMEMORY=256mb

# Application
API_HOST=0.0.0.0
API_PORT=8000
WORKERS=2
MAX_CONNECTIONS=100
KEEP_ALIVE=10

# Security (Development - Non-production keys)
SECRET_KEY=dev-secret-key-not-for-production
JWT_SECRET=dev-jwt-secret-key
ENCRYPTION_KEY=dev-encryption-key-32-characters
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# AI API Keys (Development/Testing keys)
OPENAI_API_KEY=sk-test-your-openai-dev-key
ANTHROPIC_API_KEY=sk-ant-test-your-anthropic-dev-key
HUGGINGFACE_API_KEY=hf_test-your-huggingface-dev-key
COHERE_API_KEY=test-your-cohere-dev-key

# Payment Processors (Test mode)
STRIPE_SECRET_KEY=sk_test_your_stripe_test_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_test_key
STRIPE_WEBHOOK_SECRET=whsec_test_webhook_secret
PAYPAL_CLIENT_ID=test_paypal_client_id
PAYPAL_CLIENT_SECRET=test_paypal_client_secret
PAYPAL_MODE=sandbox

# Monitoring & Observability
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
METRICS_ENABLED=true
TRACING_ENABLED=true
JAEGER_ENDPOINT=http://jaeger-dev:14268/api/traces

# Rate Limiting (Relaxed for development)
RATE_LIMIT_PER_MINUTE=10000
RATE_LIMIT_PER_HOUR=500000
RATE_LIMIT_BURST=100

# Attribution Configuration
UBA_PERCENTAGE=0.15
MINIMUM_PAYOUT_THRESHOLD=1.00
ATTRIBUTION_CONFIDENCE_THRESHOLD=0.3

# External Services (Development)
SMTP_HOST=mailhog-dev
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SECURE_MAIL=false
FROM_EMAIL=dev@uatp.local

# Cloud Storage (Development)
AWS_ACCESS_KEY_ID=dev_access_key
AWS_SECRET_ACCESS_KEY=dev_secret_key
AWS_S3_BUCKET=uatp-dev-bucket
AWS_REGION=us-west-2

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=7
BACKUP_STORAGE_TYPE=local

# Feature Flags
FEATURE_PAYMENTS=true
FEATURE_AI_ATTRIBUTION=true
FEATURE_ADVANCED_ANALYTICS=true
FEATURE_EXPERIMENTAL=true

# Development Tools
ENABLE_SWAGGER=true
ENABLE_PROFILER=true
ENABLE_DEBUG_TOOLBAR=true