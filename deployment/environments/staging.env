# UATP Staging Environment Configuration

# Environment
ENVIRONMENT=staging
DEBUG=false
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql://uatp_staging:${DATABASE_PASSWORD}@postgres-staging:5432/uatp_staging
DATABASE_HOST=postgres-staging
DATABASE_PORT=5432
DATABASE_NAME=uatp_staging
DATABASE_USER=uatp_staging
DATABASE_PASSWORD=${DATABASE_PASSWORD}
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_CONNECTION_TIMEOUT=30
DATABASE_QUERY_TIMEOUT=60

# Redis
REDIS_URL=redis://redis-staging:6379/0
REDIS_HOST=redis-staging
REDIS_PORT=6379
REDIS_DB=0
REDIS_MAXMEMORY=1gb
REDIS_PASSWORD=${REDIS_PASSWORD}

# Application
API_HOST=0.0.0.0
API_PORT=8000
WORKERS=4
MAX_CONNECTIONS=1000
KEEP_ALIVE=30
TIMEOUT_SECONDS=60

# Security
SECRET_KEY=${SECRET_KEY}
JWT_SECRET=${JWT_SECRET}
ENCRYPTION_KEY=${ENCRYPTION_KEY}
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
ENABLE_CORS=true
CORS_ORIGINS=https://staging.uatp.com,https://staging-api.uatp.com

# AI API Keys
OPENAI_API_KEY=${OPENAI_API_KEY}
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}
HUGGINGFACE_API_KEY=${HUGGINGFACE_API_KEY}
COHERE_API_KEY=${COHERE_API_KEY}

# Payment Processors (Live keys for staging testing)
STRIPE_SECRET_KEY=${STRIPE_SECRET_KEY}
STRIPE_PUBLISHABLE_KEY=${STRIPE_PUBLISHABLE_KEY}
STRIPE_WEBHOOK_SECRET=${STRIPE_WEBHOOK_SECRET}
PAYPAL_CLIENT_ID=${PAYPAL_CLIENT_ID}
PAYPAL_CLIENT_SECRET=${PAYPAL_CLIENT_SECRET}
PAYPAL_MODE=live

# Monitoring & Observability
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
METRICS_ENABLED=true
TRACING_ENABLED=true
JAEGER_ENDPOINT=http://jaeger-staging:14268/api/traces
SENTRY_DSN=${SENTRY_DSN}
SENTRY_ENVIRONMENT=staging

# Rate Limiting
RATE_LIMIT_PER_MINUTE=5000
RATE_LIMIT_PER_HOUR=250000
RATE_LIMIT_BURST=50

# Attribution Configuration
UBA_PERCENTAGE=0.15
MINIMUM_PAYOUT_THRESHOLD=5.00
ATTRIBUTION_CONFIDENCE_THRESHOLD=0.5

# External Services
SMTP_HOST=${SMTP_HOST}
SMTP_PORT=${SMTP_PORT}
SMTP_USER=${SMTP_USER}
SMTP_PASSWORD=${SMTP_PASSWORD}
SECURE_MAIL=true
FROM_EMAIL=staging@uatp.com

# Cloud Storage
AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}
AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}
AWS_S3_BUCKET=uatp-staging-bucket
AWS_REGION=us-west-2

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 1 * * *  # Daily at 1 AM
BACKUP_RETENTION_DAYS=14
BACKUP_STORAGE_TYPE=s3
BACKUP_ENCRYPTION=true

# Circuit Breaker
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_FAILURE_THRESHOLD=10
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60

# Feature Flags
FEATURE_PAYMENTS=true
FEATURE_AI_ATTRIBUTION=true
FEATURE_ADVANCED_ANALYTICS=true
FEATURE_EXPERIMENTAL=false

# Performance
ENABLE_CACHING=true
CACHE_TTL=300
ENABLE_COMPRESSION=true
ENABLE_HTTP2=true

# Development Tools (Limited in staging)
ENABLE_SWAGGER=true
ENABLE_PROFILER=false
ENABLE_DEBUG_TOOLBAR=false