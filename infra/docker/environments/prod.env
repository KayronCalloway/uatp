# UATP Production Environment Configuration

# Environment
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# Database (Production with High Availability)
DATABASE_URL=postgresql://uatp_prod:${DATABASE_PASSWORD}@postgres-prod-primary:5432/uatp_prod
DATABASE_HOST=postgres-prod-primary
DATABASE_PORT=5432
DATABASE_NAME=uatp_prod
DATABASE_USER=uatp_prod
DATABASE_PASSWORD=${DATABASE_PASSWORD}
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_CONNECTION_TIMEOUT=30
DATABASE_QUERY_TIMEOUT=60
DATABASE_SSL_MODE=require

# Read Replica Configuration
DATABASE_READ_REPLICA_URL=postgresql://uatp_prod:${DATABASE_PASSWORD}@postgres-prod-replica:5432/uatp_prod
ENABLE_READ_REPLICA=true
READ_REPLICA_RATIO=0.7

# Redis (Production with Clustering)
REDIS_URL=redis://redis-prod-cluster:6379/0
REDIS_HOST=redis-prod-cluster
REDIS_PORT=6379
REDIS_DB=0
REDIS_MAXMEMORY=4gb
REDIS_PASSWORD=${REDIS_PASSWORD}
REDIS_CLUSTER_ENABLED=true

# Application (Production Scale)
API_HOST=0.0.0.0
API_PORT=8000
WORKERS=8
MAX_CONNECTIONS=2000
KEEP_ALIVE=60
TIMEOUT_SECONDS=120
GRACEFUL_TIMEOUT=30

# Security (Production Hardened)
SECRET_KEY=${SECRET_KEY}
JWT_SECRET=${JWT_SECRET}
ENCRYPTION_KEY=${ENCRYPTION_KEY}
JWT_ALGORITHM=RS256
JWT_EXPIRATION_HOURS=1
ENABLE_CORS=true
CORS_ORIGINS=https://uatp.com,https://api.uatp.com,https://app.uatp.com
SECURE_COOKIES=true
SECURE_HEADERS=true

# AI API Keys (Production)
OPENAI_API_KEY=${OPENAI_API_KEY}
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}
HUGGINGFACE_API_KEY=${HUGGINGFACE_API_KEY}
COHERE_API_KEY=${COHERE_API_KEY}

# Payment Processors (Production)
STRIPE_SECRET_KEY=${STRIPE_SECRET_KEY}
STRIPE_PUBLISHABLE_KEY=${STRIPE_PUBLISHABLE_KEY}
STRIPE_WEBHOOK_SECRET=${STRIPE_WEBHOOK_SECRET}
PAYPAL_CLIENT_ID=${PAYPAL_CLIENT_ID}
PAYPAL_CLIENT_SECRET=${PAYPAL_CLIENT_SECRET}
PAYPAL_MODE=live

# Monitoring & Observability (Production Grade)
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
METRICS_ENABLED=true
TRACING_ENABLED=true
JAEGER_ENDPOINT=http://jaeger-prod:14268/api/traces
SENTRY_DSN=${SENTRY_DSN}
SENTRY_ENVIRONMENT=production
SENTRY_SAMPLE_RATE=0.1

# Rate Limiting (Production)
RATE_LIMIT_PER_MINUTE=1000
RATE_LIMIT_PER_HOUR=50000
RATE_LIMIT_BURST=20

# Attribution Configuration (Production)
UBA_PERCENTAGE=0.15
MINIMUM_PAYOUT_THRESHOLD=10.00
ATTRIBUTION_CONFIDENCE_THRESHOLD=0.7

# External Services (Production)
SMTP_HOST=${SMTP_HOST}
SMTP_PORT=${SMTP_PORT}
SMTP_USER=${SMTP_USER}
SMTP_PASSWORD=${SMTP_PASSWORD}
SECURE_MAIL=true
FROM_EMAIL=noreply@uatp.com

# Cloud Storage (Production)
AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}
AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}
AWS_S3_BUCKET=uatp-prod-bucket
AWS_REGION=us-west-2
S3_ENCRYPTION=AES256

# Backup Configuration (Production)
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 0 * * *  # Daily at midnight
BACKUP_RETENTION_DAYS=90
BACKUP_STORAGE_TYPE=s3
BACKUP_ENCRYPTION=true
BACKUP_COMPRESSION=true
BACKUP_VERIFICATION=true

# Circuit Breaker (Production)
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=300

# Feature Flags (Production)
FEATURE_PAYMENTS=true
FEATURE_AI_ATTRIBUTION=true
FEATURE_ADVANCED_ANALYTICS=true
FEATURE_EXPERIMENTAL=false

# Performance (Production Optimized)
ENABLE_CACHING=true
CACHE_TTL=600
ENABLE_COMPRESSION=true
ENABLE_HTTP2=true
ENABLE_CDN=true
CDN_URL=https://cdn.uatp.com

# Security Headers
HSTS_MAX_AGE=31536000
CONTENT_SECURITY_POLICY=default-src 'self'; script-src 'self' 'unsafe-inline' cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline'
X_FRAME_OPTIONS=DENY
X_CONTENT_TYPE_OPTIONS=nosniff

# Development Tools (Disabled in production)
ENABLE_SWAGGER=false
ENABLE_PROFILER=false
ENABLE_DEBUG_TOOLBAR=false

# Scaling
AUTO_SCALING_ENABLED=true
MIN_REPLICAS=3
MAX_REPLICAS=20
TARGET_CPU_UTILIZATION=70
TARGET_MEMORY_UTILIZATION=80

# High Availability
ENABLE_MULTI_AZ=true
ENABLE_FAILOVER=true
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=5
HEALTH_CHECK_RETRIES=3
