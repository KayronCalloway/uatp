# UATP Development Environment Configuration
#
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp dev.env.example dev.env
# 2. Replace all CHANGE_ME values with your actual credentials
# 3. NEVER commit dev.env to version control
#
# For generating secure keys, use:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"

# ============================================
# ENVIRONMENT
# ============================================
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgresql://uatp_dev:CHANGE_ME@postgres-dev:5432/uatp_dev
DATABASE_HOST=postgres-dev
DATABASE_PORT=5432
DATABASE_NAME=uatp_dev
DATABASE_USER=uatp_dev
DATABASE_PASSWORD=CHANGE_ME
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# ============================================
# REDIS
# ============================================
REDIS_URL=redis://redis-dev:6379/0
REDIS_HOST=redis-dev
REDIS_PORT=6379
REDIS_DB=0
REDIS_MAXMEMORY=256mb

# ============================================
# APPLICATION
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
WORKERS=2
MAX_CONNECTIONS=100
KEEP_ALIVE=10

# ============================================
# SECURITY
# Generate unique keys for each environment!
# ============================================
SECRET_KEY=CHANGE_ME
JWT_SECRET=CHANGE_ME
ENCRYPTION_KEY=CHANGE_ME
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================
# AI API KEYS
# Get from: https://platform.openai.com/api-keys
#           https://console.anthropic.com/
#           https://huggingface.co/settings/tokens
# ============================================
OPENAI_API_KEY=CHANGE_ME
ANTHROPIC_API_KEY=CHANGE_ME
HUGGINGFACE_API_KEY=CHANGE_ME
COHERE_API_KEY=CHANGE_ME

# ============================================
# PAYMENT PROCESSORS (Test Mode)
# Get test keys from Stripe/PayPal dashboards
# ============================================
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
PAYPAL_CLIENT_ID=CHANGE_ME
PAYPAL_CLIENT_SECRET=CHANGE_ME
PAYPAL_MODE=sandbox

# ============================================
# MONITORING & OBSERVABILITY
# ============================================
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
METRICS_ENABLED=true
TRACING_ENABLED=true
JAEGER_ENDPOINT=http://jaeger-dev:14268/api/traces

# ============================================
# RATE LIMITING (Relaxed for development)
# ============================================
RATE_LIMIT_PER_MINUTE=10000
RATE_LIMIT_PER_HOUR=500000
RATE_LIMIT_BURST=100

# ============================================
# ATTRIBUTION
# ============================================
UBA_PERCENTAGE=0.15
MINIMUM_PAYOUT_THRESHOLD=1.00
ATTRIBUTION_CONFIDENCE_THRESHOLD=0.3

# ============================================
# EMAIL (Use mailhog for local dev)
# ============================================
SMTP_HOST=mailhog-dev
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SECURE_MAIL=false
FROM_EMAIL=dev@uatp.local

# ============================================
# CLOUD STORAGE
# Use localstack or minio for local development
# ============================================
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_S3_BUCKET=uatp-dev-bucket
AWS_REGION=us-west-2

# ============================================
# BACKUP
# ============================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=7
BACKUP_STORAGE_TYPE=local

# ============================================
# FEATURE FLAGS
# ============================================
FEATURE_PAYMENTS=true
FEATURE_AI_ATTRIBUTION=true
FEATURE_ADVANCED_ANALYTICS=true
FEATURE_EXPERIMENTAL=true

# ============================================
# DEVELOPMENT TOOLS
# ============================================
ENABLE_SWAGGER=true
ENABLE_PROFILER=true
ENABLE_DEBUG_TOOLBAR=true
