# UATP Production Secrets Template
#
# ============================================
# DO NOT COMMIT ACTUAL SECRETS TO VERSION CONTROL
# ============================================
#
# Create the actual secrets using kubectl:
#   kubectl create secret generic uatp-secrets \
#     --from-literal=DATABASE_PASSWORD='...' \
#     --from-literal=JWT_SECRET='...' \
#     -n uatp-production
#
# Or use External Secrets Operator in production.

apiVersion: v1
kind: Secret
metadata:
  name: uatp-secrets
  namespace: uatp-production
  labels:
    app: uatp
    environment: production
type: Opaque
stringData:
  # Database
  DATABASE_PASSWORD: "CHANGE_ME"
  DATABASE_URL: "postgresql://uatp_user:CHANGE_ME@postgresql-service:5432/uatp_production"

  # Redis
  REDIS_URL: "redis://redis-service:6379/0"

  # AI API Keys (Get from provider dashboards)
  OPENAI_API_KEY: "CHANGE_ME"
  ANTHROPIC_API_KEY: "CHANGE_ME"
  HUGGINGFACE_API_KEY: "CHANGE_ME"
  COHERE_API_KEY: "CHANGE_ME"

  # Payment Processors (Use live keys for production)
  STRIPE_SECRET_KEY: "CHANGE_ME"
  STRIPE_PUBLISHABLE_KEY: "CHANGE_ME"
  STRIPE_WEBHOOK_SECRET: "CHANGE_ME"
  PAYPAL_CLIENT_ID: "CHANGE_ME"
  PAYPAL_CLIENT_SECRET: "CHANGE_ME"

  # Security (Generate unique keys)
  # Use: python -c "import secrets; print(secrets.token_urlsafe(32))"
  SECRET_KEY: "CHANGE_ME"
  JWT_SECRET: "CHANGE_ME"
  ENCRYPTION_KEY: "CHANGE_ME"

  # External Services
  SMTP_PASSWORD: "CHANGE_ME"
  SENTRY_DSN: "CHANGE_ME"

  # AWS (Use IAM roles in production when possible)
  AWS_ACCESS_KEY_ID: "CHANGE_ME"
  AWS_SECRET_ACCESS_KEY: "CHANGE_ME"
