# UATP Capsule Engine - Production Environment Configuration
# Copy this file to .env.production for production deployment
# IMPORTANT: Replace all placeholder values with actual production secrets

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
ENVIRONMENT=production
LOG_LEVEL=WARNING
API_VERSION=v1

# Application Ports
APP_PORT=8000
HEALTH_PORT=8080
METRICS_PORT=9090

# =============================================================================
# DATABASE CONFIGURATION - PostgreSQL (Production)
# =============================================================================
DATABASE_URL=postgresql+asyncpg://uatp_user:CHANGE_THIS_PASSWORD@localhost:5432/uatp_production
DB_HOST=localhost
DB_PORT=5432
DB_NAME=uatp_production
DB_USERNAME=uatp_user
DB_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD

# Connection Pool Settings (Production Optimized)
UATP_DB_POOL_SIZE=10
UATP_DB_MAX_OVERFLOW=20
UATP_DB_POOL_RECYCLE=3600

# SSL Settings (Enable for production)
DB_SSL_ENABLED=true
DB_SSL_MODE=require

# =============================================================================
# SECURITY CONFIGURATION - CRITICAL FOR PRODUCTION
# =============================================================================
# JWT Settings (GENERATE SECURE KEYS)
JWT_SECRET_KEY=CHANGE_THIS_TO_SECURE_256_BIT_KEY
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# UATP Core Security Keys (REQUIRED)
UATP_SIGNING_KEY=CHANGE_THIS_TO_64_CHAR_HEX_KEY
UATP_AGENT_ID=production-uatp-system

# Encryption Keys (GENERATE SECURE KEYS)
ENCRYPTION_KEY=CHANGE_THIS_TO_SECURE_FERNET_KEY

# API Keys (Configure for production)
API_KEYS_CONFIG='{"prod-api-key":{"permissions":["read","write"],"agent_id":"production-client","description":"Production API key"},"admin-key":{"permissions":["read","write","admin"],"agent_id":"production-admin","description":"Administrative access"}}'

# =============================================================================
# EXTERNAL AI SERVICES
# =============================================================================
# OpenAI Configuration
OPENAI_API_KEY=sk-your-production-openai-api-key
OPENAI_ORG_ID=org-your-production-org-id

# Anthropic Configuration
ANTHROPIC_API_KEY=sk-ant-api03-your-production-anthropic-key

# =============================================================================
# PRODUCTION SECURITY SETTINGS
# =============================================================================
# HTTPS and Security Headers
SECURE_SSL_REDIRECT=true
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
SECURE_HSTS_SECONDS=31536000
SECURE_CONTENT_TYPE_NOSNIFF=true
SECURE_BROWSER_XSS_FILTER=true

# CORS (Restrict to production domains)
CORS_ORIGINS=https://your-production-domain.com,https://api.your-domain.com

# Rate Limiting (Production)
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_BURST=20

# =============================================================================
# ETHICS AND SECURITY SYSTEMS
# =============================================================================
# Ethics Circuit Breaker
UATP_ETHICS_ENABLE_REFUSAL=true
UATP_ETHICS_STRICT_MODE=true

# Security Manager Settings
UATP_SECURITY_LEVEL=HIGH
UATP_QUANTUM_RESISTANT=true
UATP_REAL_TIME_MONITORING=true

# =============================================================================
# PRODUCTION LOGGING AND MONITORING
# =============================================================================
# Structured Logging
LOG_FORMAT=json
LOG_FILE=/var/log/uatp/uatp.log
ACCESS_LOG=/var/log/uatp/access.log
ERROR_LOG=/var/log/uatp/error.log

# Audit Logging
ENABLE_AUDIT_LOGGING=true
AUDIT_LOG_FILE=/var/log/uatp/audit.log

# Prometheus Metrics
PROMETHEUS_METRICS_ENABLED=true
PROMETHEUS_PORT=9091

# =============================================================================
# FEATURE FLAGS (Production)
# =============================================================================
ENABLE_SWAGGER_UI=false  # Disable in production
ENABLE_METRICS_ENDPOINT=true
ENABLE_HEALTH_ENDPOINT=true
ENABLE_REAL_TIME_EVENTS=true

# Debug Features (Disable in production)
DEBUG=false
TESTING=false
RELOAD=false

# =============================================================================
# BACKUP AND MAINTENANCE
# =============================================================================
BACKUP_RETENTION_DAYS=90
BACKUP_SCHEDULE=0 2 * * *
MAINTENANCE_WINDOW=0 3 * * SUN

# =============================================================================
# PERFORMANCE SETTINGS
# =============================================================================
# Worker Configuration
WORKER_COUNT=4
WORKER_TIMEOUT=300
MAX_REQUESTS_PER_WORKER=10000

# Memory Management
MAX_MEMORY_USAGE_MB=2048
GC_THRESHOLD=100

# =============================================================================
# PRODUCTION DEPLOYMENT INFO
# =============================================================================
DEPLOYMENT_VERSION=1.0.0
DEPLOYMENT_ENV=production
DEPLOYMENT_DATE=$(date -u +%Y-%m-%dT%H:%M:%SZ)

# Health Check Configuration
HEALTH_CHECK_TIMEOUT=30
READINESS_TIMEOUT=60

# =============================================================================
# OPTIONAL: CLOUD SERVICES
# =============================================================================
# AWS (if using cloud deployment)
# AWS_ACCESS_KEY_ID=your_production_aws_key
# AWS_SECRET_ACCESS_KEY=your_production_aws_secret
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=uatp-production-storage

# Redis (if using for caching)
# REDIS_URL=redis://localhost:6379/0
# REDIS_PASSWORD=your_secure_redis_password

# =============================================================================
# SSL CERTIFICATES (if self-managed)
# =============================================================================
# SSL_CERT_PATH=/etc/ssl/certs/uatp.crt
# SSL_KEY_PATH=/etc/ssl/private/uatp.key
# SSL_CA_PATH=/etc/ssl/certs/ca.crt
