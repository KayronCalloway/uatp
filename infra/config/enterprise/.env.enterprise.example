# UATP Capsule Engine - Enterprise Configuration
# Copy this file to .env.enterprise and update with your values

# =============================================================================
# CORE CONFIGURATION
# =============================================================================

# Environment
UATP_ENV=production
DEBUG=false
LOG_LEVEL=INFO

# Application Settings
APP_NAME="UATP Capsule Engine Enterprise"
APP_VERSION=7.0.0-enterprise
BASE_URL=https://uatp-enterprise.your-company.com

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL Database
DB_PASSWORD=your-super-secure-db-password
DATABASE_URL=postgresql://uatp_user:${DB_PASSWORD}@postgres:5432/uatp_enterprise
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30

# Database Backup Configuration
DB_BACKUP_ENABLED=true
DB_BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM
DB_BACKUP_RETENTION_DAYS=30

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=8
JWT_REFRESH_TOKEN_DAYS=30

# Encryption
BCRYPT_ROUNDS=12
AES_ENCRYPTION_KEY=your-32-character-encryption-key

# Session Security
SESSION_SECURE_COOKIES=true
SESSION_HTTPONLY_COOKIES=true
SESSION_SAMESITE=strict

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================

REDIS_URL=redis://redis:6379/0
REDIS_SESSION_DB=1
REDIS_CACHE_DB=2
REDIS_RATE_LIMIT_DB=3
REDIS_PASSWORD=your-redis-password

# =============================================================================
# ENTERPRISE FEATURES
# =============================================================================

# Multi-Tenant Configuration
MULTI_TENANT_ENABLED=true
DEFAULT_ORGANIZATION_TIER=startup
ENABLE_ORGANIZATION_SIGNUP=false

# Enterprise Features
ENTERPRISE_FEATURES_ENABLED=true
SSO_ENABLED=true
GOVERNANCE_ENABLED=true
COMPLIANCE_REPORTING_ENABLED=true
ADVANCED_ANALYTICS_ENABLED=true

# =============================================================================
# SINGLE SIGN-ON (SSO) CONFIGURATION
# =============================================================================

# General SSO Settings
SSO_SESSION_TIMEOUT=28800  # 8 hours
SSO_MAX_SESSIONS_PER_USER=5
MFA_REQUIRED=true

# Azure AD Configuration
AZURE_AD_TENANT_ID=your-azure-tenant-id
AZURE_AD_CLIENT_ID=your-azure-client-id
AZURE_AD_CLIENT_SECRET=your-azure-client-secret

# Okta Configuration
OKTA_DOMAIN=your-okta-domain.okta.com
OKTA_CLIENT_ID=your-okta-client-id
OKTA_CLIENT_SECRET=your-okta-client-secret

# Google Workspace Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# SAML Configuration
SAML_ENTITY_ID=https://uatp-enterprise.your-company.com
SAML_CERTIFICATE_PATH=/app/config/saml/saml.crt
SAML_PRIVATE_KEY_PATH=/app/config/saml/saml.key

# =============================================================================
# RATE LIMITING AND QUOTAS
# =============================================================================

# Rate Limiting
RATE_LIMITING_ENABLED=true
RATE_LIMITING_STORAGE=redis
DEFAULT_RATE_LIMIT_RPM=1000
DEFAULT_RATE_LIMIT_RPH=10000
DEFAULT_RATE_LIMIT_RPD=100000

# Usage Tracking
USAGE_TRACKING_ENABLED=true
BILLING_ENABLED=true
OVERAGE_BILLING_ENABLED=true

# =============================================================================
# COMPLIANCE CONFIGURATION
# =============================================================================

# Audit Logging
AUDIT_LOG_ENABLED=true
AUDIT_LOG_LEVEL=comprehensive
AUDIT_LOG_RETENTION_DAYS=2555  # 7 years
AUDIT_LOG_STORAGE=database

# Compliance Frameworks
GDPR_MODE=true
HIPAA_MODE=false
SOX_MODE=false
ISO27001_MODE=false

# Data Retention
DEFAULT_DATA_RETENTION_DAYS=2555
PII_DATA_RETENTION_DAYS=2555
LOG_DATA_RETENTION_DAYS=2555

# Privacy Settings
PRIVACY_BY_DESIGN=true
CONSENT_MANAGEMENT_ENABLED=true
DATA_SUBJECT_RIGHTS_ENABLED=true

# =============================================================================
# FILE STORAGE CONFIGURATION
# =============================================================================

# Storage Type (local, s3, azure, google)
FILE_STORAGE_TYPE=s3

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=uatp-enterprise-storage
AWS_S3_REGION=us-east-1
AWS_S3_ENDPOINT_URL=  # Optional for S3-compatible services

# Azure Blob Storage Configuration
AZURE_STORAGE_ACCOUNT_NAME=your-storage-account
AZURE_STORAGE_ACCOUNT_KEY=your-storage-key
AZURE_STORAGE_CONTAINER=uatp-enterprise

# Google Cloud Storage Configuration
GOOGLE_CLOUD_PROJECT=your-gcp-project
GOOGLE_CLOUD_BUCKET=uatp-enterprise-storage
GOOGLE_APPLICATION_CREDENTIALS=/app/config/gcp/service-account.json

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

# SMTP Settings
SMTP_HOST=smtp.your-company.com
SMTP_PORT=587
SMTP_USERNAME=noreply@your-company.com
SMTP_PASSWORD=your-smtp-password
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Email Settings
FROM_EMAIL=noreply@your-company.com
ADMIN_EMAIL=admin@your-company.com
SUPPORT_EMAIL=support@your-company.com

# =============================================================================
# MONITORING AND OBSERVABILITY
# =============================================================================

# Prometheus Metrics
PROMETHEUS_METRICS_ENABLED=true
PROMETHEUS_METRICS_PORT=8001

# Structured Logging
STRUCTURED_LOGGING_ENABLED=true
LOG_FORMAT=json

# Error Tracking
SENTRY_DSN=your-sentry-dsn
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Health Checks
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_TIMEOUT=30

# =============================================================================
# WEBHOOK CONFIGURATION
# =============================================================================

# Webhook Settings
WEBHOOK_ENABLED=true
WEBHOOK_SECRET=your-webhook-secret
WEBHOOK_TIMEOUT=30
WEBHOOK_RETRY_ATTEMPTS=3

# =============================================================================
# BACKUP AND DISASTER RECOVERY
# =============================================================================

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 1 * * *"  # Daily at 1 AM
BACKUP_RETENTION_DAYS=90
BACKUP_ENCRYPTION_ENABLED=true

# S3 Backup Configuration
BACKUP_S3_BUCKET=uatp-enterprise-backups
BACKUP_S3_REGION=us-east-1

# =============================================================================
# PERFORMANCE CONFIGURATION
# =============================================================================

# Application Performance
WORKER_PROCESSES=4
WORKER_CONNECTIONS=1000
KEEPALIVE_TIMEOUT=75

# Cache Settings
CACHE_ENABLED=true
CACHE_DEFAULT_TIMEOUT=3600
CACHE_MAX_ENTRIES=10000

# Database Connection Pool
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30

# =============================================================================
# GRAFANA CONFIGURATION
# =============================================================================

# Grafana Admin
GRAFANA_ADMIN_PASSWORD=your-grafana-admin-password

# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================

# Load Balancer
LOAD_BALANCER_ENABLED=true
STICKY_SESSIONS=true

# Auto Scaling
AUTO_SCALING_ENABLED=false
MIN_REPLICAS=2
MAX_REPLICAS=10
CPU_THRESHOLD=70

# Blue-Green Deployment
BLUE_GREEN_DEPLOYMENT=false
DEPLOYMENT_STRATEGY=rolling

# =============================================================================
# DEVELOPMENT AND TESTING
# =============================================================================

# Development Settings (only for development)
DEV_MODE=false
HOT_RELOAD=false
DEBUG_TOOLBAR=false

# Testing
TEST_DATABASE_URL=postgresql://uatp_test:test_password@localhost:5432/uatp_test
RUN_TESTS_ON_STARTUP=false

# =============================================================================
# CUSTOM CONFIGURATION
# =============================================================================

# Organization-specific settings
DEFAULT_TIMEZONE=UTC
DEFAULT_LANGUAGE=en
FEATURE_FLAGS=sso,governance,compliance,analytics

# Custom Integrations
CUSTOM_INTEGRATIONS_ENABLED=true
WEBHOOK_ENDPOINTS=
API_RATE_LIMIT_WHITELIST=

# =============================================================================
# SECURITY HEADERS AND POLICIES
# =============================================================================

# CORS Settings
CORS_ORIGINS=https://uatp-enterprise.your-company.com,https://admin.your-company.com
CORS_CREDENTIALS=true
CORS_MAX_AGE=86400

# Content Security Policy
CSP_DEFAULT_SRC='self'
CSP_SCRIPT_SRC='self' 'unsafe-inline'
CSP_STYLE_SRC='self' 'unsafe-inline'
CSP_IMG_SRC='self' data: https:

# Security Headers
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=true

# =============================================================================
# MAINTENANCE MODE
# =============================================================================

# Maintenance
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE="System is under maintenance. Please try again later."
MAINTENANCE_ALLOWED_IPS=127.0.0.1,10.0.0.0/8

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log Levels
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_DATABASE=WARNING
LOG_LEVEL_HTTP=INFO
LOG_LEVEL_SECURITY=INFO

# Log Rotation
LOG_ROTATION_ENABLED=true
LOG_MAX_SIZE=100MB
LOG_BACKUP_COUNT=10

# =============================================================================
# THIRD-PARTY INTEGRATIONS
# =============================================================================

# Slack Integration
SLACK_WEBHOOK_URL=your-slack-webhook-url
SLACK_CHANNEL=#uatp-alerts

# Microsoft Teams Integration
TEAMS_WEBHOOK_URL=your-teams-webhook-url

# PagerDuty Integration
PAGERDUTY_INTEGRATION_KEY=your-pagerduty-key

# =============================================================================
# LICENSING
# =============================================================================

# Enterprise License
ENTERPRISE_LICENSE_KEY=your-enterprise-license-key
LICENSE_CHECK_INTERVAL=86400  # 24 hours

# Feature Licensing
ADVANCED_ANALYTICS_LICENSE=true
COMPLIANCE_REPORTING_LICENSE=true
SSO_INTEGRATION_LICENSE=true
