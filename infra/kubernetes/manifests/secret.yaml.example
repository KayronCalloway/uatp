# UATP Kubernetes Secrets Template
#
# ============================================
# DO NOT COMMIT ACTUAL SECRETS TO GIT
# ============================================
#
# This is a TEMPLATE file. In production, use one of these approaches:
#
# 1. External Secrets Operator (Recommended)
#    - AWS Secrets Manager
#    - HashiCorp Vault
#    - Azure Key Vault
#    - Google Secret Manager
#
# 2. Sealed Secrets (Bitnami)
#    kubeseal --format yaml < secret.yaml > sealed-secret.yaml
#
# 3. SOPS (Mozilla)
#    sops -e secret.yaml > secret.enc.yaml
#
# To create secrets manually for local development:
#   kubectl create secret generic uatp-secrets \
#     --from-literal=DATABASE_URL='your-db-url' \
#     --from-literal=JWT_SECRET='your-jwt-secret' \
#     ...
#
# To base64 encode a value:
#   echo -n 'your-value' | base64

---
apiVersion: v1
kind: Secret
metadata:
  name: uatp-secrets
  namespace: uatp-dev
  labels:
    app: uatp
    environment: development
type: Opaque
stringData:
  # Use stringData for plain text (Kubernetes will base64 encode)
  # Replace CHANGE_ME with actual values
  DATABASE_URL: "CHANGE_ME"
  REDIS_URL: "CHANGE_ME"
  UATP_SIGNING_KEY: "CHANGE_ME"
  JWT_SECRET: "CHANGE_ME"
  OPENAI_API_KEY: "CHANGE_ME"
  ANTHROPIC_API_KEY: "CHANGE_ME"

---
apiVersion: v1
kind: Secret
metadata:
  name: uatp-secrets
  namespace: uatp-staging
  labels:
    app: uatp
    environment: staging
type: Opaque
stringData:
  # For staging, use External Secrets Operator to inject from secrets manager
  DATABASE_URL: "CHANGE_ME"
  REDIS_URL: "CHANGE_ME"
  UATP_SIGNING_KEY: "CHANGE_ME"
  JWT_SECRET: "CHANGE_ME"
  OPENAI_API_KEY: "CHANGE_ME"
  ANTHROPIC_API_KEY: "CHANGE_ME"

---
apiVersion: v1
kind: Secret
metadata:
  name: uatp-secrets
  namespace: uatp-prod
  labels:
    app: uatp
    environment: production
type: Opaque
stringData:
  # PRODUCTION: NEVER store actual values here
  # Use External Secrets Operator or Sealed Secrets
  DATABASE_URL: "INJECT_FROM_SECRETS_MANAGER"
  REDIS_URL: "INJECT_FROM_SECRETS_MANAGER"
  UATP_SIGNING_KEY: "INJECT_FROM_SECRETS_MANAGER"
  JWT_SECRET: "INJECT_FROM_SECRETS_MANAGER"
  OPENAI_API_KEY: "INJECT_FROM_SECRETS_MANAGER"
  ANTHROPIC_API_KEY: "INJECT_FROM_SECRETS_MANAGER"
