import base64
import logging
import zlib
from datetime import timedelta
from typing import Dict, Union

from src.capsule_schema import AnyCapsule
from src.engine.exceptions import UATPEngineError
from quart import Blueprint, Response, g, jsonify
from quart_rate_limiter import rate_limit
from quart_schema import validate_querystring, validate_request, validate_response

from .dependencies import cache_response_headers, get_engine, require_api_key
from .schemas import (
    CapsuleDetailResponse,
    CapsuleListResponse,
    CompressedCapsuleListResponse,
    CapsuleStatsResponse,
    ErrorResponse,
    GetCapsuleQuery,
    ListCapsulesQuery,
    VerificationResponse,
    CreateReasoningCapsuleRequest,
    CapsuleCreationResponse,
)

logger = logging.getLogger(__name__)


def get_ethics_info():
    """Get ethics circuit breaker information."""
    try:
        engine = get_engine()
        if hasattr(engine, "ethics_circuit_breaker"):
            stats = engine.ethics_circuit_breaker.get_refusal_statistics()
            recent_refusals = engine.ethics_circuit_breaker.get_recent_refusals(
                hours=24
            )
            return {
                "ethics_enabled": True,
                "refusal_statistics": stats,
                "recent_refusals_count": len(recent_refusals),
                "strict_mode": engine.ethics_circuit_breaker.strict_mode,
                "refusal_threshold": engine.ethics_circuit_breaker.refusal_threshold,
            }
        else:
            return {"ethics_enabled": False}
    except Exception as e:
        logger.error(f"Error getting ethics info: {e}")
        return {"ethics_enabled": False, "error": str(e)}


capsules_bp = Blueprint("capsules", __name__, url_prefix="/capsules")


@capsules_bp.route("/ethics", methods=["GET"])
@require_api_key(["read"])
async def get_ethics_status():
    """Get ethics circuit breaker status and statistics."""
    try:
        ethics_info = get_ethics_info()
        return jsonify(ethics_info)
    except Exception as e:
        logger.error(f"Error getting ethics status: {e}")
        return jsonify({"error": str(e)}), 500


def compress_capsule_data(data: Dict) -> Dict:
    """Compresses the payload of a capsule's dictionary representation."""
    # This function might need adjustment depending on which fields are large
    if "payload" in data and isinstance(data["payload"], dict):
        for key, value in data["payload"].items():
            if isinstance(value, str) and len(value) > 1024:  # Compress large strings
                data["payload"][key] = base64.b64encode(
                    zlib.compress(value.encode())
                ).decode()
    return data


@capsules_bp.route("", methods=["GET", "OPTIONS"])
@require_api_key(["read"])
# @cache_response_headers(ttl_seconds=60)  # TEMPORARILY DISABLED FOR TESTING
@validate_querystring(ListCapsulesQuery)
@validate_response(CompressedCapsuleListResponse, 200)
async def list_capsules(
    query_args: ListCapsulesQuery,
) -> Union[CompressedCapsuleListResponse, Response]:
    """List all capsules in the chain, with pagination."""
    engine = get_engine()
    skip = (query_args.page - 1) * query_args.per_page
    limit = query_args.per_page

    try:
        print(f"🔍🔍🔍 API ROUTE: demo_mode={query_args.demo_mode}, exclude_demo={not query_args.demo_mode}", flush=True)
        logger.info(f"🔍 API ROUTE: demo_mode={query_args.demo_mode}, exclude_demo={not query_args.demo_mode}")
        paginated_chain = await engine.load_chain_async(
            skip=skip,
            limit=limit,
            exclude_demo=not query_args.demo_mode  # Exclude demo capsules if not in demo mode
        )
        print(f"🔍🔍🔍 API ROUTE: Retrieved {len(paginated_chain)} capsules from engine", flush=True)
        logger.info(f"🔍 API ROUTE: Retrieved {len(paginated_chain)} capsules from engine")
        # Convert Pydantic models to dictionaries to ensure proper serialization
        capsule_dicts = []
        for capsule in paginated_chain:
            capsule_dict = capsule.model_dump()
            capsule_dicts.append(capsule_dict)
        return CompressedCapsuleListResponse(capsules=capsule_dicts)
    except Exception as e:
        logger.error(f"Error listing capsules: {e}", exc_info=True)
        return ErrorResponse(error="Failed to list capsules", details=str(e)), 500


@capsules_bp.route("/<capsule_id>", methods=["GET", "OPTIONS"])
@require_api_key(["read"])
@cache_response_headers(ttl_seconds=60)
@validate_querystring(GetCapsuleQuery)
@validate_response(CapsuleDetailResponse, 200)
async def get_capsule(
    capsule_id: str, query_args: GetCapsuleQuery
) -> Union[CapsuleDetailResponse, Response]:
    """Get a specific capsule by ID."""
    try:
        engine = get_engine()
        found_capsule = await engine.load_capsule_async(capsule_id=capsule_id)
        if not found_capsule:
            return ErrorResponse(error="Capsule not found"), 404

        response_data = CapsuleDetailResponse(capsule=found_capsule.model_dump())

        if query_args.include_raw:
            try:
                response_data.raw_data = {
                    "original_json": found_capsule.model_dump_json(),
                    "capsule_model": str(found_capsule.__class__.__name__),
                }
            except Exception as raw_err:
                response_data.raw_data = {
                    "error": "Could not generate raw data",
                    "reason": str(raw_err),
                }
        return response_data
    except Exception as e:
        logger.error(f"Error retrieving capsule {capsule_id}: {e}", exc_info=True)
        return ErrorResponse(error="Failed to retrieve capsule", details=str(e)), 500


@capsules_bp.route("/<string:capsule_id>/verify", methods=["GET", "OPTIONS"])
@require_api_key(["read"])
@cache_response_headers(ttl_seconds=120)
@validate_response(VerificationResponse, 200)
async def verify_capsule(capsule_id: str) -> Union[VerificationResponse, Response]:
    """Verify a specific capsule by ID with comprehensive security verification."""
    try:
        engine = get_engine()
        capsule_to_verify = await engine.load_capsule_async(capsule_id=capsule_id)
        if not capsule_to_verify:
            return ErrorResponse(error="Capsule not found"), 404

        # Standard cryptographic verification
        is_valid, reason = await engine.verify_capsule_async(capsule_to_verify)

        # Enhanced security verification if security manager available
        security_verification = None
        if hasattr(engine, "security_manager") and engine.security_manager:
            try:
                # Initialize security systems if needed
                if not engine._security_initialized:
                    await engine.initialize_security_systems()

                # Prepare capsule data for security verification
                capsule_data = {
                    "capsule_id": capsule_to_verify.capsule_id,
                    "content": getattr(capsule_to_verify, "reasoning_trace", {})
                    or str(capsule_to_verify),
                    "timestamp": capsule_to_verify.timestamp.isoformat(),
                    "capsule_type": capsule_to_verify.capsule_type.value,
                    "contributor_id": engine.agent_id,
                    "signature": getattr(
                        capsule_to_verify.verification, "signature", None
                    ),
                    "public_key": getattr(
                        capsule_to_verify.verification, "public_key", None
                    ),
                }

                # Perform comprehensive security verification
                (
                    security_success,
                    security_result,
                ) = await engine.security_manager.secure_capsule_operation(
                    "capsule_verification", capsule_data
                )

                security_verification = {
                    "security_verified": security_success,
                    "verification_rate": security_result.get("verification_rate", 0),
                    "security_details": security_result.get(
                        "security_verifications", {}
                    ),
                    "quantum_resistant": security_result.get("quantum_signatures", {})
                    != {},
                }

                logger.info(
                    f"✅ Security verification for capsule {capsule_id}: {security_result.get('verification_rate', 0):.2%} success rate"
                )

            except Exception as security_error:
                logger.warning(
                    f"Security verification failed for capsule {capsule_id}: {security_error}"
                )
                security_verification = {
                    "security_verified": False,
                    "security_error": str(security_error),
                }

        response_data = {
            "capsule_id": capsule_id,
            "verified": is_valid,
            "verification_error": reason if not is_valid else None,
        }

        # Add security verification results if available
        if security_verification:
            response_data["security_verification"] = security_verification

        return VerificationResponse(**response_data)

    except Exception as e:
        logger.error(f"Error verifying capsule {capsule_id}: {e}", exc_info=True)
        return ErrorResponse(error="Failed to verify capsule", details=str(e)), 500


@capsules_bp.route("/stats", methods=["GET", "OPTIONS"])
@require_api_key(["read"])
@rate_limit(120, timedelta(minutes=1))
@cache_response_headers(ttl_seconds=120)
@validate_response(CapsuleStatsResponse, 200)
async def get_capsule_stats() -> Union[CapsuleStatsResponse, Response]:
    """Get statistics about the capsules in the chain."""
    try:
        engine = get_engine()
        all_capsules = await engine.load_chain_async(limit=-1)  # Get all
        types_count = {}
        agent_ids = set()
        for capsule in all_capsules:
            types_count[capsule.capsule_type.value] = (
                types_count.get(capsule.capsule_type.value, 0) + 1
            )
            if capsule.verification and capsule.verification.signer:
                agent_ids.add(capsule.verification.signer)

        return CapsuleStatsResponse(
            total_capsules=len(all_capsules),
            types=types_count,
            unique_agents=len(agent_ids),
        )
    except Exception as e:
        logger.error(f"Error getting stats: {e}", exc_info=True)
        return ErrorResponse(error="Failed to get stats", details=str(e)), 500


@capsules_bp.route("", methods=["POST"])
@require_api_key(["write"])
@rate_limit(100, timedelta(minutes=1))
@validate_request(CreateReasoningCapsuleRequest)
@validate_response(CapsuleCreationResponse, 201)
async def create_reasoning_capsule(
    data: CreateReasoningCapsuleRequest,
) -> Union[CapsuleCreationResponse, Response]:
    """Create a new reasoning trace capsule."""
    try:
        engine = get_engine()
        # The agent_id is now part of the signature, set by the engine
        agent_id = getattr(g, "agent_id", None)
        if not agent_id:
            return ErrorResponse(error="Agent ID not found in request context"), 400
        engine.agent_id = agent_id

        # Create reasoning capsule with auto-generated fields
        import uuid
        from datetime import datetime, timezone
        from src.capsule_schema import (
            ReasoningTraceCapsule,
            Verification,
            CapsuleStatus,
            CapsuleType,
        )

        now = datetime.now(timezone.utc)
        capsule_id = (
            f"caps_{now.year}_{now.month:02d}_{now.day:02d}_{uuid.uuid4().hex[:16]}"
        )

        # Create the capsule with auto-generated fields
        capsule = ReasoningTraceCapsule(
            capsule_id=capsule_id,
            version="7.0",
            timestamp=now,
            capsule_type=CapsuleType.REASONING_TRACE,
            status=data.status,
            verification=Verification(),  # Empty verification, will be populated by create_capsule_async
            reasoning_trace=data.reasoning_trace,
        )

        # Use secure capsule creation with comprehensive security verification
        new_capsule = await engine.create_secure_capsule_async(capsule)

        return (
            CapsuleCreationResponse(
                capsule_id=new_capsule.capsule_id,
                status="created_secure",
                message="Reasoning trace capsule created successfully with security verification",
                capsule=new_capsule,
            ),
            201,
        )
    except UATPEngineError as e:
        logger.error(f"Failed to create reasoning capsule: {e}", exc_info=True)
        return ErrorResponse(error="Failed to create capsule", details=str(e)), 400
    except Exception as e:
        logger.error(f"An unexpected error occurred: {e}", exc_info=True)
        return ErrorResponse(error="An unexpected error occurred", details=str(e)), 500


@capsules_bp.route("/generic", methods=["POST"])
@require_api_key(["write"])
@rate_limit(100, timedelta(minutes=1))
@validate_request(AnyCapsule)
@validate_response(CapsuleCreationResponse, 201)
async def create_generic_capsule(
    data: AnyCapsule,
) -> Union[CapsuleCreationResponse, Response]:
    """Create a fully-formed capsule (for advanced users who provide complete capsule data)."""
    try:
        engine = get_engine()
        # The agent_id is now part of the signature, set by the engine
        agent_id = getattr(g, "agent_id", None)
        if not agent_id:
            return ErrorResponse(error="Agent ID not found in request context"), 400
        engine.agent_id = agent_id

        # Use secure capsule creation with comprehensive security verification
        new_capsule = await engine.create_secure_capsule_async(data)

        return (
            CapsuleCreationResponse(
                capsule_id=new_capsule.capsule_id,
                status="created_secure",
                capsule=new_capsule,
            ),
            201,
        )
    except UATPEngineError as e:
        logger.error(f"Failed to create generic capsule: {e}", exc_info=True)
        return ErrorResponse(error="Failed to create capsule", details=str(e)), 400
    except Exception as e:
        logger.error(f"An unexpected error occurred: {e}", exc_info=True)
        return ErrorResponse(error="An unexpected error occurred", details=str(e)), 500
