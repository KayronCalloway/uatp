{
  "name": "uatp-dev-capture",
  "displayName": "UATP Development Capture",
  "description": "Universal AI Accountability for Development Workflows - Capture all AI-assisted coding, decisions, and interactions (Built: 20250901_090308)",
  "version": "2.0.0",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other",
    "Machine Learning",
    "Data Science",
    "Snippets"
  ],
  "keywords": [
    "ai",
    "attribution",
    "copilot",
    "chatgpt",
    "claude",
    "accountability",
    "uatp",
    "tracking",
    "ethics"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:uatp.startCapture",
    "onLanguage:*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "uatp.startCapture",
        "title": "Start UATP Capture Session",
        "category": "UATP"
      },
      {
        "command": "uatp.endCapture",
        "title": "End UATP Capture Session",
        "category": "UATP"
      },
      {
        "command": "uatp.captureCurrentFile",
        "title": "Capture Current File Changes",
        "category": "UATP"
      },
      {
        "command": "uatp.viewDashboard",
        "title": "Open UATP Dashboard",
        "category": "UATP"
      },
      {
        "command": "uatp.toggleAutoCapture",
        "title": "Toggle Auto-Capture",
        "category": "UATP"
      },
      {
        "command": "uatp.captureAIInteraction",
        "title": "Capture AI Interaction",
        "category": "UATP"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "uatp.startCapture",
          "when": "!uatp.sessionActive"
        },
        {
          "command": "uatp.endCapture",
          "when": "uatp.sessionActive"
        }
      ],
      "editor/context": [
        {
          "command": "uatp.captureCurrentFile",
          "group": "uatp",
          "when": "editorTextFocus"
        },
        {
          "command": "uatp.captureAIInteraction",
          "group": "uatp",
          "when": "editorTextFocus"
        }
      ],
      "explorer/context": [
        {
          "command": "uatp.captureCurrentFile",
          "group": "uatp",
          "when": "resourceLangId"
        }
      ]
    },
    "configuration": {
      "title": "UATP Development Capture",
      "properties": {
        "uatp.apiBase": {
          "type": "string",
          "default": "http://localhost:8000",
          "description": "UATP API base URL"
        },
        "uatp.apiKey": {
          "type": "string",
          "default": "dev-key-001",
          "description": "UATP API key for authentication"
        },
        "uatp.autoCapture": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic capture of development activities"
        },
        "uatp.captureThreshold": {
          "type": "number",
          "default": 0.6,
          "minimum": 0,
          "maximum": 1,
          "description": "Significance threshold for automatic capture (0-1)"
        },
        "uatp.captureFileChanges": {
          "type": "boolean",
          "default": true,
          "description": "Automatically capture file changes and edits"
        },
        "uatp.captureTerminalOutput": {
          "type": "boolean",
          "default": true,
          "description": "Capture terminal commands and outputs"
        },
        "uatp.captureGitActivity": {
          "type": "boolean",
          "default": true,
          "description": "Capture Git commits, branches, and merges"
        },
        "uatp.showNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show notifications when captures are created"
        },
        "uatp.monitoredFileTypes": {
          "type": "array",
          "default": [
            "javascript",
            "typescript",
            "python",
            "java",
            "csharp",
            "cpp",
            "go",
            "rust",
            "php",
            "ruby",
            "swift",
            "kotlin"
          ],
          "description": "File types to monitor for automatic capture"
        }
      }
    },
    "views": {
      "uatp": [
        {
          "id": "uatp.sessions",
          "name": "Active Sessions",
          "contextualTitle": "UATP Sessions"
        },
        {
          "id": "uatp.stats",
          "name": "Capture Statistics",
          "contextualTitle": "UATP Stats"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "uatp",
          "title": "UATP",
          "icon": "$(package)"
        }
      ]
    },
    "keybindings": [
      {
        "command": "uatp.startCapture",
        "key": "ctrl+shift+u ctrl+s",
        "mac": "cmd+shift+u cmd+s",
        "when": "!uatp.sessionActive"
      },
      {
        "command": "uatp.endCapture",
        "key": "ctrl+shift+u ctrl+e",
        "mac": "cmd+shift+u cmd+e",
        "when": "uatp.sessionActive"
      },
      {
        "command": "uatp.captureCurrentFile",
        "key": "ctrl+shift+u ctrl+f",
        "mac": "cmd+shift+u cmd+f"
      },
      {
        "command": "uatp.toggleAutoCapture",
        "key": "ctrl+shift+u ctrl+a",
        "mac": "cmd+shift+u cmd+a"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "typescript": "^4.9.4"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "chokidar": "^3.5.3",
    "diff": "^5.1.0"
  },
  "publisher": "uatp",
  "repository": {
    "type": "git",
    "url": "https://github.com/uatp/vscode-extension"
  },
  "homepage": "https://uatp.app/extensions/vscode",
  "bugs": {
    "url": "https://github.com/uatp/vscode-extension/issues"
  },
  "license": "MIT",
  "icon": "images/uatp-icon.png",
  "galleryBanner": {
    "color": "#667eea",
    "theme": "dark"
  }
}