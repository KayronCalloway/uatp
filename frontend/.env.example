# UATP Frontend Environment Configuration
# Copy this to .env.local and adjust as needed
#
# =============================================================================
# SECURITY NOTES
# =============================================================================
# - NEVER commit .env.local to version control
# - API keys should only be set via environment variables, never hardcoded
# - In production, set NEXT_PUBLIC_UATP_API_KEY via secure deployment config
#
# =============================================================================

# Backend API Configuration (REQUIRED)
NEXT_PUBLIC_UATP_API_URL=http://localhost:8000

# API Key (REQUIRED for authenticated endpoints)
# SECURITY: Generate a unique key for production
# NEXT_PUBLIC_UATP_API_KEY=your-api-key-here

# Feature Flags
NEXT_PUBLIC_ENABLE_REAL_API=true
NEXT_PUBLIC_ENABLE_MOCK_FALLBACK=true

# Development Settings
NEXT_PUBLIC_DEBUG_MODE=true
NEXT_PUBLIC_ENVIRONMENT=development

# Optional: WebSocket for live updates
NEXT_PUBLIC_WEBSOCKET_URL=ws://localhost:8000/ws
NEXT_PUBLIC_METRICS_ENABLED=true

# =============================================================================
# BUILD CONFIGURATION
# =============================================================================
# By default, TypeScript and ESLint errors will fail the build (recommended).
# Only set these to 'true' if you have a critical deployment blocker.
#
# SKIP_TYPE_CHECK=false
# SKIP_LINT_CHECK=false
