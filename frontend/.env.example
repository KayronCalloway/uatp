# UATP Frontend Environment Configuration
# Copy this to .env.local and adjust as needed

# Backend API Configuration
NEXT_PUBLIC_UATP_API_URL=http://localhost:8000

# Feature Flags
NEXT_PUBLIC_ENABLE_REAL_API=true
NEXT_PUBLIC_ENABLE_MOCK_FALLBACK=true

# Development Settings
NEXT_PUBLIC_DEBUG_MODE=true
NEXT_PUBLIC_ENVIRONMENT=development

# Optional: WebSocket for live updates
NEXT_PUBLIC_WEBSOCKET_URL=ws://localhost:8000/ws
NEXT_PUBLIC_METRICS_ENABLED=true
