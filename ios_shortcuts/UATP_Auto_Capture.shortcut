# UATP Auto Capture iOS Shortcut
# This creates a Share Sheet integration that appears in ChatGPT/Claude apps

# Shortcut Configuration:
# 1. Trigger: Share Sheet
# 2. Input: Text from any app
# 3. Action: Auto-send to UATP backend

actions:
  - name: "Get Text from Input"
    type: "get_variable"
    variable: "Provided Input"
    
  - name: "Detect Platform"
    type: "if"
    condition: "Provided Input contains 'ChatGPT' or current app is 'ChatGPT'"
    then:
      - set_variable: "platform" value: "openai"
    else:
      - set_variable: "platform" value: "claude"
      
  - name: "Format Conversation"
    type: "text"
    text: |
      {
        "session_id": "ios-shortcut-{{current_timestamp}}",
        "user_id": "ios_user", 
        "platform": "{{platform}}",
        "messages": [
          {
            "role": "user",
            "content": "{{conversation_text}}"
          }
        ]
      }
      
  - name: "Send to UATP"
    type: "get_contents_of_url"
    url: "http://YOUR_MAC_IP:9090/api/v1/live/capture/batch"
    method: "POST"
    headers:
      "Content-Type": "application/json"
      "X-API-Key": "your_api_key"
    body: "{{formatted_json}}"
    
  - name: "Show Success"
    type: "show_notification"
    text: "Conversation captured in UATP! ✅"

# Usage Instructions:
# 1. Long-press text in ChatGPT/Claude
# 2. Tap "Share"
# 3. Select "UATP Auto Capture"
# 4. Conversation automatically sent to backend