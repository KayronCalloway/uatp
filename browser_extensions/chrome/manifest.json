{
  "manifest_version": 3,
  "name": "UATP Universal AI Capture",
  "version": "2.0.0",
  "description": "Automatically capture and attribute all AI conversations across the web for universal accountability",
  
  "permissions": [
    "activeTab",
    "storage",
    "background",
    "scripting",
    "tabs",
    "webRequest",
    "declarativeNetRequest"
  ],
  
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://www.perplexity.ai/*",
    "https://character.ai/*",
    "https://poe.com/*",
    "https://bard.google.com/*",
    "https://gemini.google.com/*",
    "https://copilot.microsoft.com/*",
    "https://huggingface.co/chat/*",
    "https://labs.google/*",
    "http://localhost:*"
  ],
  
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://claude.ai/*", 
        "https://www.perplexity.ai/*",
        "https://character.ai/*",
        "https://poe.com/*",
        "https://bard.google.com/*",
        "https://gemini.google.com/*",
        "https://copilot.microsoft.com/*",
        "https://huggingface.co/chat/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ],
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "UATP AI Capture",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  
  "web_accessible_resources": [
    {
      "resources": ["injected.js", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ],
  
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "uatp_capture_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}